# Copy to .env.local and fill in. NEVER commit .env.local.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser — keep secrets unprefixed.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server only — SECRET, bypasses RLS) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (server only) ---
# Used by the postgres MCP and migration tooling. Point at LOCAL/dev, not prod.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
